{
  "name": "@sealkeeper/e2e",
  "version": "0.1.0-dev",
  "description": "Playwright end-to-end suite for SealKeeper (PRD module L §3.3).",
  "type": "module",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "playwright test",
    "test:happy": "playwright test --project=chromium --grep=\"@happy-path\"",
    "test:nightly": "playwright test --grep=\"@nightly\"",
    "test:a11y": "playwright test --grep=\"@a11y\"",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3"
  }
}
