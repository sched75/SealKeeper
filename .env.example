# =============================================================================
# SealKeeper — Environment template / Modèle d'environnement
# =============================================================================
# Copy this file to `.env` and fill in the values:
#   cp .env.example .env && ${EDITOR:-vi} .env
#
# Copiez ce fichier vers `.env` puis renseignez les valeurs :
#   cp .env.example .env && ${EDITOR:-vi} .env
#
# Legend / Légende:
#   [MUST]      Required in production / Requis en production
#   [SHOULD]    Recommended / Recommandé
#   [OPTIONAL]  Optional / Optionnel
#
# PRD reference: module H §3.5 (FR-H.13..15), module D §3.9 (FR-D.64+).
# =============================================================================


# -----------------------------------------------------------------------------
# Image / Image
# -----------------------------------------------------------------------------
# [SHOULD] EN: Pin the image tag for reproducible production deployments.
#          FR: Épinglez une version pour des déploiements reproductibles.
SK_IMAGE=ghcr.io/sealkeeper/sealkeeper:latest


# -----------------------------------------------------------------------------
# Mode + URLs / Mode + URLs
# -----------------------------------------------------------------------------
# [MUST] EN: `eval` for the 5-second evaluation mode (SQLite, captured SMTP,
#        auto master secret, orange banner). `production` for real deployments.
#        FR: `eval` pour le mode évaluation 5 secondes (SQLite, SMTP capturé,
#        master secret auto, bandeau orange). `production` en production.
SK_MODE=production

# [MUST] EN: Public URL exposed to end users — used for cookie domain and
#        absolute links in emails.
#        FR: URL publique exposée aux utilisateurs — utilisée pour le domaine
#        des cookies et les liens absolus dans les emails.
SK_BASE_URL=https://sealkeeper.example.com

# [OPTIONAL] EN: Bare hostname used by Caddy for ACME (Let's Encrypt).
#            FR: Nom d'hôte simple utilisé par Caddy pour ACME (Let's Encrypt).
SK_DOMAIN=sealkeeper.example.com

# [OPTIONAL] EN: Contact email for Let's Encrypt account.
#            FR: Email de contact pour le compte Let's Encrypt.
ACME_EMAIL=ops@example.com

# [OPTIONAL] EN: Override host ports (default 80/443). Useful when sharing a
#            host with another reverse proxy.
#            FR: Surcharge des ports hôte (défaut 80/443). Utile si l'hôte
#            héberge déjà un autre reverse proxy.
SK_HTTP_PORT=80
SK_HTTPS_PORT=443


# -----------------------------------------------------------------------------
# Master secret / Secret maître
# -----------------------------------------------------------------------------
# [MUST] EN: 32 random bytes, base64-encoded. Generate ONCE per deployment,
#        store outside the instance (vault, External Secrets, etc.). Losing
#        this value makes every encrypted artifact unrecoverable.
#        FR: 32 octets aléatoires encodés en base64. À générer UNE seule fois
#        par déploiement, à stocker hors de l'instance (coffre, External
#        Secrets, etc.). Sa perte rend irrécupérables les artefacts chiffrés.
#
#   Generate / Générer :
#     openssl rand -base64 32
#
SK_MASTER_SECRET=REPLACE_ME_WITH_BASE64_32_BYTES


# -----------------------------------------------------------------------------
# Database / Base de données
# -----------------------------------------------------------------------------
# [MUST] EN: Postgres credentials used by the bundled docker-compose Postgres.
#        FR: Identifiants Postgres utilisés par le service Postgres embarqué.
POSTGRES_DB=sealkeeper
POSTGRES_USER=sealkeeper
POSTGRES_PASSWORD=REPLACE_ME_WITH_STRONG_PASSWORD

# [OPTIONAL] EN: Override the full DSN if you point at an external database.
#            FR: Surchargez le DSN complet si vous pointez vers une base externe.
# SK_DATABASE_URL=postgres://user:pass@db.example.com:5432/sealkeeper?sslmode=require


# -----------------------------------------------------------------------------
# Logging / Journalisation
# -----------------------------------------------------------------------------
# [SHOULD] EN: `json` for prod (machine-readable), `text` for development.
#          FR: `json` en prod (lisible par machine), `text` en développement.
SK_LOG_FORMAT=json

# [SHOULD] EN: One of debug, info, warn, error.
#          FR: Une valeur parmi debug, info, warn, error.
SK_LOG_LEVEL=info


# -----------------------------------------------------------------------------
# Trusted proxies / Proxies de confiance
# -----------------------------------------------------------------------------
# [MUST when behind a reverse proxy] EN: Comma-separated CIDRs allowed to set
#        X-Forwarded-* headers (FR-H.42, D-H.22). Default value covers the
#        docker bridge subnet used by the bundled Compose stack.
#        FR: CIDRs autorisés à positionner les en-têtes X-Forwarded-*
#        séparés par des virgules. La valeur par défaut couvre le sous-réseau
#        bridge utilisé par la stack Compose embarquée.
SK_TRUSTED_PROXY_CIDRS=172.16.0.0/12


# -----------------------------------------------------------------------------
# Metrics endpoint / Endpoint métriques
# -----------------------------------------------------------------------------
# [OPTIONAL] EN: If set, /metrics requires `Authorization: Bearer <token>`.
#            Leave empty for unauthenticated scrape (network-restricted).
#            FR: Si renseigné, /metrics exige `Authorization: Bearer <token>`.
#            Laisser vide pour un scrape non authentifié (réseau cloisonné).
SK_METRICS_TOKEN=


# -----------------------------------------------------------------------------
# Sessions and limits / Sessions et limites
# -----------------------------------------------------------------------------
# [OPTIONAL — defaults are sane / Optionnel — valeurs par défaut raisonnables]
SK_MAX_LIBRARY_SIZE_MB=10
SK_MAX_ACTIVE_SESSIONS=10000
SK_SESSION_TTL_SECONDS=900          # 15 min — user session
SK_ADMIN_SESSION_TTL_SECONDS=28800  # 8 h    — admin session
SK_ADMIN_SESSION_IDLE_SECONDS=1800  # 30 min — admin idle timeout


# -----------------------------------------------------------------------------
# Feature flags / Indicateurs de fonctionnalité
# -----------------------------------------------------------------------------
# [OPTIONAL] EN: Expose Swagger UI at /api/docs. Off by default in production
#            (FR-H.13). Useful for staging.
#            FR: Expose Swagger UI à /api/docs. Désactivé par défaut en prod
#            (FR-H.13). Utile en staging.
SK_SWAGGER_UI_ENABLED=false

# [OPTIONAL] EN: Public demo mode (FR-H.78). Read-only-ish presentation
#            intended for a public preview instance. Off by default.
#            FR: Mode démo public (FR-H.78). Présentation quasi en lecture
#            seule pour une instance publique. Désactivé par défaut.
SK_DEMO_MODE=false

# [OPTIONAL] EN: Maintenance mode — return HTTP 503 on user routes
#            (FR-H.73-74). Toggle at boot or via admin API.
#            FR: Mode maintenance — renvoie HTTP 503 sur les routes utilisateur
#            (FR-H.73-74). Basculable au démarrage ou via l'API admin.
SK_MAINTENANCE_MODE=false


# -----------------------------------------------------------------------------
# Configuration file / Fichier de configuration
# -----------------------------------------------------------------------------
# [OPTIONAL] EN: Alternate path to a YAML configuration file (FR-D.64). Lower
#            precedence than CLI flags and env vars; higher than defaults.
#            FR: Chemin alternatif vers un fichier de configuration YAML
#            (FR-D.64). Précédence inférieure aux flags CLI et variables
#            d'environnement, supérieure aux valeurs par défaut.
# SK_CONFIG_FILE=/etc/sealkeeper/config.yaml
